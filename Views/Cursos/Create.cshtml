@model ProyectoFinal_GarroRojasRosa.Models.Curso

@{
    ViewData["Title"] = "Agregar Curso";
}

<div class="card shadow">

    <div class="card-header bg-primary text-white">
        <h3 class="mb-0">📘 Agregar Curso</h3>
    </div>

    <div class="card-body">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Codigo" class="form-label fw-bold"></label>
                <input asp-for="Codigo" class="form-control" placeholder="Ingrese el código del curso" />
                <span asp-validation-for="Codigo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-bold"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Ingrese el nombre del curso" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Creditos" class="form-label fw-bold"></label>
                <input asp-for="Creditos" class="form-control" placeholder="Cantidad de créditos" />
                <span asp-validation-for="Creditos" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="Estado" class="form-check-input" />
                <label asp-for="Estado" class="form-check-label fw-bold">
                    Curso Activo
                </label>
            </div>

            <div class="d-flex gap-2">

                <button type="submit" class="btn btn-success">
                    💾 Guardar
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    ↩ Regresar
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}