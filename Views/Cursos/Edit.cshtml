@model ProyectoFinal_GarroRojasRosa.Models.Curso

@{
    ViewData["Title"] = "Editar Curso";
}

<div class="card shadow">

    <div class="card-header bg-warning">
        <h3 class="mb-0">✏️ Editar Curso</h3>
    </div>

    <div class="card-body">

        <form asp-action="Edit">

            <input type="hidden" asp-for="IdCurso" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Codigo" class="form-label fw-bold"></label>
                <input asp-for="Codigo" class="form-control" />
                <span asp-validation-for="Codigo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-bold"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Creditos" class="form-label fw-bold"></label>
                <input asp-for="Creditos" class="form-control" />
                <span asp-validation-for="Creditos" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="Estado" class="form-check-input" />
                <label asp-for="Estado" class="form-check-label fw-bold">
                    Curso Activo
                </label>
            </div>

            <button type="submit" class="btn btn-warning">
                💾 Guardar Cambios
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                ↩ Regresar
            </a>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}