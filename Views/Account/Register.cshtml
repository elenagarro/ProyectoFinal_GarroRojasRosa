@model ProyectoFinal_GarroRojasRosa.Models.RegisterViewModel

@{
    ViewData["Title"] = "Registro";
}

<div class="row justify-content-center mt-5">

    <div class="col-lg-6">

        <div class="card shadow-lg border-0">

            <div class="card-header bg-primary text-white text-center py-4">

                <img src="~/images/logo.jpg"
                     width="80"
                     class="rounded-circle mb-3" />

                <h2>Sistema de Matrícula Universitaria</h2>

                <p class="mb-0">
                    Crear una nueva cuenta
                </p>

            </div>

            <div class="card-body p-4">

                <form asp-action="Register" method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label asp-for="Nombre"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="Nombre"
                                   class="form-control"
                                   placeholder="Nombre" />

                            <span asp-validation-for="Nombre"
                                  class="text-danger">
                            </span>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label asp-for="Apellido"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="Apellido"
                                   class="form-control"
                                   placeholder="Apellido" />

                            <span asp-validation-for="Apellido"
                                  class="text-danger">
                            </span>

                        </div>

                    </div>

                    <div class="mb-3">

                        <label asp-for="Email"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Email"
                               class="form-control"
                               placeholder="correo@universidad.com" />

                        <span asp-validation-for="Email"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="mb-3">

                        <label asp-for="Password"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Password"
                               class="form-control"
                               placeholder="********" />

                        <span asp-validation-for="Password"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="ConfirmPassword"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="ConfirmPassword"
                               class="form-control"
                               placeholder="********" />

                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger">
                        </span>

                    </div>

                    <button type="submit"
                            class="btn btn-success btn-lg w-100">

                        Registrarse

                    </button>

                </form>

                <hr />

                <div class="text-center">

                    ¿Ya tiene una cuenta?

                    <a asp-controller="Account"
                       asp-action="Login">

                        Iniciar sesión

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}