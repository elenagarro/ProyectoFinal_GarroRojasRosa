@model ProyectoFinal_GarroRojasRosa.Models.Carrera

@{
    ViewData["Title"] = "Agregar Carrera";
}

<div class="card shadow">

    <div class="card-header bg-primary text-white">
        <h3 class="mb-0">🎓 Agregar Carrera</h3>
    </div>

    <div class="card-body">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-bold"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Ingrese el nombre de la carrera" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label fw-bold"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Descripción de la carrera"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="Estado" class="form-check-input" />
                <label asp-for="Estado" class="form-check-label fw-bold">
                    Carrera Activa
                </label>
            </div>

            <button type="submit" class="btn btn-success">
                💾 Guardar
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                ↩ Regresar
            </a>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}