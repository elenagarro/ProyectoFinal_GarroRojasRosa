@model ProyectoFinal_GarroRojasRosa.Models.Carrera

@{
    ViewData["Title"] = "Detalles de la Carrera";
}

<div class="card shadow">

    <div class="card-header bg-info text-white">

        <h3>🎓 Detalles de la Carrera</h3>

    </div>

    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre</dd>

            <dt class="col-sm-3">Descripción</dt>
            <dd class="col-sm-9">@Model.Descripcion</dd>

            <dt class="col-sm-3">Estado</dt>

            <dd class="col-sm-9">

                @if (Model.Estado)
                {
                    <span class="badge bg-success">Activa</span>
                }
                else
                {
                    <span class="badge bg-danger">Inactiva</span>
                }

            </dd>

        </dl>

    </div>

    <div class="card-footer">

        <a asp-action="Edit"
           asp-route-id="@Model.IdCarrera"
           class="btn btn-warning">

            Editar

        </a>

        <a asp-action="Index"
           class="btn btn-secondary">

            Regresar

        </a>

    </div>

</div>